# Suppress funding and audit messages to keep output clean
fund=false
audit=false

# Use warn log level to reduce noise; set to 'error' for even quieter installs
loglevel=warn

# Prefer locally cached packages over network downloads
# Reduces downloads on repeated installs and helps on slow/metered connections
prefer-offline=true

# Limit the number of concurrent network requests to reduce memory and I/O pressure
# Helps avoid "no space left on device" errors on low-resource machines
maxsockets=3
